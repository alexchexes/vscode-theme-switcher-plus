  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2024",
    "lib": ["ES2024"],
    "outDir": "out",
    "sourceMap": true,
    "strict": true,
    "rootDir": "src",
