{
  "name": "theme-switcher-plus",
  "displayName": "Theme Switcher+",
  "description": "Use hotkeys to change themes or cycle through theme lists.",
  "version": "0.3.0",
  "publisher": "AlexChexes",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#947500",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexchexes/vscode-theme-switcher-plus"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "theme",
    "switcher",
    "hotkey",
    "switch",
    "command",
    "toggle",
    "cycle",
    "change",
    "select",
    "list",
    "global",
    "workspace",
    "preset",
    "syntax",
    "textmate",
    "day",
    "night",
    "dark",
    "light"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "main": "./out/extension.js",
  "files": [
    "out",
    "images/icon.png",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.mjs",
    "test:watch": "vitest --config vitest.config.mjs",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit",
    "check": "pnpm run format:check && pnpm run lint && pnpm run compile && pnpm run test && pnpm run test:typecheck",
    "package": "pnpm exec vsce package --no-dependencies",
    "install-local": "pnpm run package && node scripts/install-local.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.13.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.39.0",
    "vitest": "^4.1.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "themeSwitcher.nextInstalledTheme",
        "title": "Next Installed Theme",
        "category": "Theme Switcher+"
      },
      {
        "command": "themeSwitcher.previousInstalledTheme",
        "title": "Previous Installed Theme",
        "category": "Theme Switcher+"
      },
      {
        "command": "themeSwitcher.randomInstalledTheme",
        "title": "Random Installed Theme",
        "category": "Theme Switcher+"
      },
      {
        "command": "themeSwitcher.nextThemeInList",
        "title": "Next Theme In List",
        "category": "Theme Switcher+"
      },
      {
        "command": "themeSwitcher.previousThemeInList",
        "title": "Previous Theme In List",
        "category": "Theme Switcher+"
      },
      {
        "command": "themeSwitcher.randomThemeInList",
        "title": "Random Theme In List",
        "category": "Theme Switcher+"
      },
      {
        "command": "themeSwitcher.setTheme",
        "title": "Set Theme",
        "category": "Theme Switcher+"
      }
    ],
    "keybindings": [
      {
        "command": "themeSwitcher.previousInstalledTheme",
        "key": "ctrl+shift+F11",
        "mac": "cmd+shift+F11"
      },
      {
        "command": "themeSwitcher.nextInstalledTheme",
        "key": "ctrl+shift+F12",
        "mac": "cmd+shift+F12"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Theme Switcher+",
      "properties": {
        "themeSwitcher.themeLists": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "required": [
              "id",
              "themes"
            ],
            "properties": {
              "id": {
                "type": "string",
                "markdownDescription": "Stable list identifier used in `themeSwitcher.nextThemeInList`, `themeSwitcher.previousThemeInList`, and `themeSwitcher.randomThemeInList` args."
              },
              "themes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "markdownDescription": "Theme names cycled by this list."
              }
            },
            "additionalProperties": false
          },
          "markdownDescription": "Ordered custom theme lists. User and workspace lists are merged, and workspace lists override matching `id` values. Use each list `id` with `themeSwitcher.nextThemeInList`, `themeSwitcher.previousThemeInList`, or `themeSwitcher.randomThemeInList`."
        }
      }
    }
  }
}
